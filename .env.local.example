# Postgres — matches docker-compose.dev.yml
DATABASE_URL=postgres://datafast:datafast@localhost:5433/datafast

# Better-Auth
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption of DataFast API keys at rest.
# Required in production (NODE_ENV=production throws without it).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# DASHBOARD_ENCRYPTION_KEY=

# Resend (optional in dev — falls back to console log).
# Required for sending verification / password-reset emails in production.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="DataFast <noreply@dash.example.com>"

# OAuth providers (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
