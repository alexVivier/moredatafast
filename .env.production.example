# Production environment — copy to .env.production on the VPS and fill in.
# Do NOT commit .env.production.

NODE_ENV=production

# ---- Docker image to deploy (set by CI, overridable for manual pinning) ----
APP_IMAGE=ghcr.io/YOUR_GITHUB_USER/datafast-dashboard:latest

# ---- Caddy -------------------------------------------------------------
# The FQDN Caddy will serve (and auto-provision a Let's Encrypt cert for).
CADDY_DOMAIN=dash.example.com

# ---- Postgres ----------------------------------------------------------
POSTGRES_USER=datafast
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=datafast
# Postgres host MUST stay as "postgres" (docker service name).
DATABASE_URL=postgres://datafast:CHANGE_ME@postgres:5432/datafast

# ---- Better-Auth -------------------------------------------------------
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME
BETTER_AUTH_URL=https://dash.example.com
NEXT_PUBLIC_APP_URL=https://dash.example.com

# ---- Encryption of DataFast API keys at rest --------------------------
# Generate: openssl rand -base64 32
# Losing this key means losing access to every stored DataFast API key.
DASHBOARD_ENCRYPTION_KEY=CHANGE_ME

# ---- Resend (transactional email) -------------------------------------
# Create at resend.com, verify your sender domain via DKIM/SPF.
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=DataFast <noreply@dash.example.com>

# ---- OAuth (optional) -------------------------------------------------
# Create a GitHub OAuth app: https://github.com/settings/developers
# Callback URL: https://dash.example.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Create Google OAuth credentials (Web): https://console.cloud.google.com
# Redirect URI: https://dash.example.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- DataFast self-tracking -------------------------------------------
# The dashboard uses DataFast to analyse its own traffic. Grab the website
# ID from your DataFast site's "Install script" screen.
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=

# ---- Stripe billing ---------------------------------------------------
# Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# Publishable key is inlined at build time (NEXT_PUBLIC_*), passed via CI
# build-args. Safe to expose client-side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
# Stripe Dashboard → Developers → Webhooks → add endpoint
# https://dash.example.com/api/auth/stripe/webhook with events:
# customer.subscription.{created,updated,deleted}, invoice.{paid,payment_failed}.
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# Product "DataFast Premium" → monthly recurring price id.
STRIPE_PRICE_PREMIUM_MONTHLY=price_CHANGE_ME
# Optional: annual recurring price id (offer a yearly discount).
STRIPE_PRICE_PREMIUM_YEARLY=

# ---- Webhook dispatcher cron ------------------------------------------
# Shared secret used by the crontab that polls DataFast every minute and
# fans events out to user-configured webhooks. Generate: openssl rand -base64 32
CRON_SECRET=CHANGE_ME
